                        </Button>
                     </children>
                  </VBox>
                  <VBox alignment="BOTTOM_CENTER" prefHeight="100.0" prefWidth="88.0" stylesheets="@dashboard.css">
                     <children>
                        <Button mnemonicParsing="false" onAction="#generateReport" prefHeight="39.0" prefWidth="86.0" styleClass="Sbutton" stylesheets="@dashboard.css" text="   Print">
