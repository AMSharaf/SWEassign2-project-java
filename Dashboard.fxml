            <Text fill="#fafafa" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="title" text="Current Dashboard">
               <font>
                  <Font name="System Bold" size="40.0" />
               </font></Text>
            <BorderPane />
            <VBox alignment="CENTER_RIGHT" prefHeight="70.0" prefWidth="986.0">
               <children>
                  <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#handleLogout" prefHeight="39.0" prefWidth="78.0" styleClass="Sbutton" stylesheets="@dashboard.css" text="Logout">
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Button>
               </children>
            </VBox>
         </children>
      </HBox>
   </top>
   <bottom>
      <HBox prefHeight="0.0" prefWidth="830.0" spacing="15.0" BorderPane.alignment="CENTER" />
