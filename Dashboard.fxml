      <VBox prefHeight="542.0" prefWidth="980.0" spacing="20.0" styleClass="dashboard" stylesheets="@dashboard.css" BorderPane.alignment="CENTER">
         <children>
            <HBox prefHeight="100.0" prefWidth="200.0" spacing="15.0">
               <children>
