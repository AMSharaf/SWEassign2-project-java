<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="1200.0" styleClass="root" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
   <left>
      <VBox prefHeight="200.0" prefWidth="220.0" spacing="20.0" styleClass="sidebar" stylesheets="@dashboard.css" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="title" stylesheets="@dashboard.css" text="Masroofy">
