                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Button>
               </children>
            </VBox>
            <VBox prefHeight="122.0" prefWidth="180.0" styleClass="box" stylesheets="@dashboard.css">
               <children>
                  <TextField fx:id="expenseField" promptText="Add Expense" styleClass="inputField" stylesheets="@dashboard.css" />
                  <ComboBox fx:id="chooseCategory" prefWidth="150.0" promptText="Category" styleClass="inputField" stylesheets="@dashboard.css" />
                  <Button mnemonicParsing="false" onAction="#handleAddExpense" prefHeight="36.0" prefWidth="145.0" styleClass="Sbutton" stylesheets="@dashboard.css" text="           Add">
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Button>
               </children>
            </VBox>
         </children>
      </VBox>
   </left>
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="1200.0" spacing="15.0" styleClass="topbar" stylesheets="@dashboard.css" BorderPane.alignment="CENTER">
