            </Label>
            <VBox alignment="CENTER" prefHeight="74.0" prefWidth="180.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#goToAddBudget" prefHeight="36.0" prefWidth="133.0" styleClass="Sbutton" stylesheets="@dashboard.css" text="   Add Budget" textAlignment="CENTER" textFill="WHITE">
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Button>
               </children>
            </VBox>
            <VBox alignment="TOP_CENTER" prefHeight="126.0" prefWidth="180.0" styleClass="box" stylesheets="@dashboard.css">
